{
	"name": "detain/myadmin-maxmind-plugin",
	"type": "myadmin-plugin",
	"description": "MaxMind handling plugin for MyAdmin",
	"keywords": [
		"abuse",
		"administration",
		"spam"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https:\/\/my.interserver.net\/"
		}
	],
	"config": {
		"bin-dir": "vendor\/bin",
		"allow-plugins": {
			"detain/myadmin-plugin-installer": true
		}
	},
	"require": {
		"php": ">=5.0.0",
		"ext-curl": "*",
		"symfony/event-dispatcher": "*@stable",
		"detain/myadmin-plugin-installer": "dev-master",
		"maxmind/minfraud": "*",
		"minfraud/http": "*"
    },
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminMaxMind\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminMaxMind\\Tests\\": "tests/"
		}
	},
	"repositories": [
		{
			"type": "git",
			"url": "https://github.com/detain/ccfd-api-php"
		}
	]
}
